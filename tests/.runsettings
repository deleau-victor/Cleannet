<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <ResultsDirectory>./TestResults</ResultsDirectory>
  </RunConfiguration>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage" enabled="true">
        <Configuration>
          <Format>cobertura,opencover</Format>
          <ExcludeByAttribute>ObsoleteAttribute,GeneratedCodeAttribute,CompilerGeneratedAttribute,ExcludeFromCodeCoverageAttribute</ExcludeByAttribute>
          <Exclude>
            [AspireHost]*,
            [ServiceDefaults]*,
            [*]*.Converters.*,
            [*]*.DependencyInjection.*,
            [*]*.Options.*,
            [*]*.Errors.*,
            [*]*.Dtos.*,
            [*]*.Constants.*,
            [*]*.Migrations.*,
            [*]*.Extensions.*
          </Exclude>
          <ExcludeByFile>**/Program.cs,**/ServiceDefaults/*.cs,**/AspireHost/*.cs</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
